# Copy this file to backend/.env or set these variables in your system environment.
# Never commit a real API key.
# Language model provider. Supported: deepseek, openai.
LLM_PROVIDER=deepseek

# DeepSeek. If omitted, backend will try to read ../keys/ds.txt.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI is still supported as an optional fallback provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Image provider. Supported: dashscope, none.
IMAGE_PROVIDER=dashscope

# DashScope / 通义万相. If omitted, backend will try to read ../keys/*.csv.
DASHSCOPE_API_KEY=
DASHSCOPE_IMAGE_MODEL=wanx2.1-t2i-turbo

# Optional: override the local SQLite database path.
# FACADEGPT_DB=D:/FileK/facadegpt2/backend/facadegpt.db
